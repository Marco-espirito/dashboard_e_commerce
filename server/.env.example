# Connexion PostgreSQL (adapte user / password / nom de la base)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/admin_rbac?schema=public"

# Secret pour signer les access tokens JWT (mets une longue chaîne aléatoire en prod)
JWT_SECRET="change-moi-avec-une-longue-chaine-aleatoire"
JWT_EXPIRES_IN="15m"

# Secret pour signer les refresh tokens (différent du JWT_SECRET)
REFRESH_SECRET="change-moi-avec-une-autre-longue-chaine-aleatoire"

# Port du serveur
PORT=4000

# Origine autorisée pour le CORS (le frontend Vite par défaut)
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# Admin initial créé par "npm run seed:admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin1234!"
ADMIN_NAME="Super Admin"
