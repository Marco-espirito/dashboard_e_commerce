generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Verrouillage de compte après échecs de connexion répétés
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?

  // Suppression logique (soft delete) — préserve les références FK
  // (audit logs, historique de statut) tout en désactivant le compte.
  deletedAt DateTime?

  // Trace de l'admin qui a créé ce membre
  createdById String?
  createdBy   User?    @relation("CreatedMembers", fields: [createdById], references: [id])
  members     User[]   @relation("CreatedMembers")
  orderStatusChanges OrderStatusHistory[]
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]
}

// Refresh tokens stockés côté serveur pour permettre la révocation
// On stocke le jti (JWT ID) et non le token brut.
model RefreshToken {
  id         String    @id @default(cuid())
  jti        String    @unique          // identifiant unique embarqué dans le JWT
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?                  // null = actif, non-null = révoqué
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())  // mis à jour à chaque refresh
  userAgent  String?                    // navigateur / OS de l'appareil
  ipAddress  String?                    // adresse IP de connexion

  @@index([userId])
  @@index([expiresAt])
}
enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Product {
  id         String      @id @default(cuid())
  name       String
  price      Int // prix en centimes (évite les flottants)
  stock      Int         @default(0)
  initialStock Int       @default(0)
  category   String?
  createdAt  DateTime    @default(now())
  orderItems OrderItem[]
}

model Order {
  id        String      @id @default(cuid())
  customer  String // nom du client (simplifié)
  status    OrderStatus @default(PAID)
  total     Int // total en centimes
  createdAt DateTime    @default(now())
  items     OrderItem[]
  statusHistory OrderStatusHistory[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Int // prix au moment de la commande (centimes)
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AuditEntity {
  PRODUCT
  MEMBER
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  entity      AuditEntity
  entityId    String
  entityLabel String      // nom/email au moment de l'action (persiste si l'entité est supprimée)
  metadata    Json?       // diff optionnel { field: { from: x, to: y } }
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  createdAt   DateTime    @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus
  toStatus   OrderStatus
  changedById String
  changedBy   User      @relation(fields: [changedById], references: [id])
  createdAt DateTime    @default(now())
}
